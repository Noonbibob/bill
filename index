<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Advance Bill Generator</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
    <style>
        body {
            background-color: #f3f4f6;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        }
        .bill-card {
            width: 350px;
            background: white;
            padding: 20px;
            border-radius: 8px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }
        #bill-preview-container {
            position: absolute;
            left: -9999px;
            top: 0;
        }
        .touch-button {
            transition: transform 0.1s;
        }
        .touch-button:active {
            transform: scale(0.95);
        }
    </style>
</head>
<body class="p-4 flex flex-col items-center">

    <div class="w-full max-w-md bg-white rounded-2xl shadow-lg p-6 space-y-4">
        <h1 class="text-2xl font-bold text-center text-blue-600 mb-6">Showroom Advance</h1>
        
        <div class="space-y-4">
            <div>
                <label class="block text-sm font-medium text-gray-700">Customer Name</label>
                <input type="text" id="custName" placeholder="Enter name" class="mt-1 block w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-blue-500 focus:border-blue-500">
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700">Item / Model</label>
                <input type="text" id="itemName" placeholder="e.g. iPhone 15" class="mt-1 block w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-blue-500 focus:border-blue-500">
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700">Advance Amount Paid ($)</label>
                <input type="number" id="amount" placeholder="0.00" class="mt-1 block w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-blue-500 focus:border-blue-500">
            </div>

            <!-- Primary Send Button -->
            <button id="mainBtn" onclick="generateAndShare()" class="touch-button w-full bg-green-500 hover:bg-green-600 text-white font-bold py-4 rounded-xl flex items-center justify-center gap-2 text-lg shadow-md">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" />
                </svg>
                Send to WhatsApp
            </button>

            <!-- Fallback Button if Share Fails -->
            <div id="fallbackArea" class="hidden space-y-3 pt-2">
                <p class="text-xs text-center text-red-500 font-medium">Auto-share blocked. Use manual method below:</p>
                <button onclick="downloadImage()" class="w-full bg-blue-500 text-white py-3 rounded-lg font-bold">1. Save Bill Image</button>
                <button onclick="openWhatsApp()" class="w-full bg-green-600 text-white py-3 rounded-lg font-bold">2. Open WhatsApp</button>
            </div>
        </div>
    </div>

    <!-- Hidden Bill Template for Capture -->
    <div id="bill-preview-container">
        <div id="bill-receipt" class="bill-card border-2 border-gray-100">
            <div class="text-center border-b pb-4 mb-4">
                <h2 class="text-xl font-black uppercase tracking-widest text-gray-800">SHOWROOM RECEIPT</h2>
                <p class="text-xs text-gray-500 mt-1" id="receipt-date"></p>
            </div>
            
            <div class="space-y-3">
                <div class="flex justify-between border-b border-dotted pb-1">
                    <span class="text-gray-500">Customer:</span>
                    <span class="font-bold text-gray-800" id="disp-name">-</span>
                </div>
                <div class="flex justify-between border-b border-dotted pb-1">
                    <span class="text-gray-500">Item:</span>
                    <span class="font-semibold text-gray-800" id="disp-item">-</span>
                </div>
                <div class="mt-6 bg-gray-50 p-4 rounded-lg text-center">
                    <p class="text-xs text-gray-400 uppercase font-bold">Advance Amount Paid</p>
                    <p class="text-3xl font-black text-green-600" id="disp-amount">$0.00</p>
                </div>
            </div>

            <div class="mt-8 text-center border-t pt-4">
                <p class="text-sm font-medium text-gray-700 italic">"Thank you for choosing us!"</p>
                <div class="mt-2 text-[10px] text-gray-400">Transaction ID: <span id="trans-id"></span></div>
            </div>
        </div>
    </div>

    <div id="status-msg" class="fixed bottom-10 left-1/2 -translate-x-1/2 bg-black text-white px-6 py-3 rounded-full hidden text-sm shadow-xl z-50">
        Generating...
    </div>

    <script>
        let lastImageData = null;

        function showMsg(txt) {
            const status = document.getElementById('status-msg');
            status.innerText = txt;
            status.classList.remove('hidden');
            setTimeout(() => status.classList.add('hidden'), 3000);
        }

        async function generateAndShare() {
            const name = document.getElementById('custName').value;
            const amount = document.getElementById('amount').value;
            const item = document.getElementById('itemName').value;

            if (!name || !amount) {
                showMsg("Enter Name and Amount!");
                return;
            }

            document.getElementById('disp-name').innerText = name;
            document.getElementById('disp-item').innerText = item || "Showroom Item";
            document.getElementById('disp-amount').innerText = "$" + parseFloat(amount).toLocaleString();
            document.getElementById('receipt-date').innerText = new Date().toLocaleString();
            document.getElementById('trans-id').innerText = Math.random().toString(36).substr(2, 6).toUpperCase();

            showMsg("Creating Image...");

            try {
                const canvas = await html2canvas(document.getElementById('bill-receipt'), { scale: 3 });
                lastImageData = canvas.toDataURL("image/png");
                const blob = await new Promise(resolve => canvas.toBlob(resolve, 'image/png'));
                const file = new File([blob], "Bill.png", { type: "image/png" });

                if (navigator.share && navigator.canShare && navigator.canShare({ files: [file] })) {
                    await navigator.share({
                        files: [file],
                        title: 'Bill',
                        text: `Receipt for ${name}`
                    });
                } else {
                    throw new Error("Share not supported");
                }
            } catch (err) {
                console.log("Auto-share failed:", err);
                document.getElementById('fallbackArea').classList.remove('hidden');
                showMsg("Auto-share failed. Use buttons below.");
            }
        }

        function downloadImage() {
            if (!lastImageData) return;
            const link = document.createElement('a');
            link.download = `Bill_${document.getElementById('custName').value}.png`;
            link.href = lastImageData;
            link.click();
            showMsg("Image Saved to Gallery!");
        }

        function openWhatsApp() {
            const name = document.getElementById('custName').value;
            const amount = document.getElementById('amount').value;
            const msg = encodeURIComponent(`Hi ${name}, here is your receipt for $${amount}. Please attach the saved image.`);
            window.location.href = `https://wa.me/?text=${msg}`;
        }
    </script>
</body>
</html>
